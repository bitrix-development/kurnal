{
    "name": "kurnal/cms",
    "description": "Custom PHP CMS for Kurnal resort",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.6",
        "nikic/fast-route": "^1.3",
        "ezyang/htmlpurifier": "^4.17"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true
    }
}
