# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_KEY=change-this-to-a-random-string-32chars
APP_URL=https://your-domain.ru
APP_DEBUG=false

# ─── Locales ─────────────────────────────────────────────────────────────────
APP_LOCALES=ru,en
APP_DEFAULT_LOCALE=ru

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kurnal_cms
DB_USER=kurnal_user
DB_PASS=your_strong_password_here
DB_CHARSET=utf8mb4
